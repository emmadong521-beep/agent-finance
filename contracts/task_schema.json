{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-os.local/contracts/task_schema.json",
  "title": "Task",
  "description": "A unit of work submitted to an Agent OS executor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "description"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "workflow_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
