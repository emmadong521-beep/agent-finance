# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Shell scripts
*.sh text eol=lf

# Gitkeep
.gitkeep text
